@model LoginViewModel
@*
    Form đăng nhập dùng chung: trang đầy đủ (/dang-nhap) và popup (modal qua auth.js).
    Dùng heading thường (không <h1>) để khi hiện trong modal trên trang khác không tạo
    H1 thứ hai. Trang /dang-nhap là NoIndex nên không ảnh hưởng SEO.
*@
<div class="auth-head">@Html.Icon("door-open", 24) Đăng nhập</div>
<p class="muted text-center small mb-10">Chào mừng quay lại Diễn đàn Cửa.</p>

<form asp-action="Login" method="post" novalidate data-login-form>
    <input type="hidden" asp-for="ReturnUrl" />
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors mb-10"></div>

    <div class="field">
        <label asp-for="UserNameOrEmail"></label>
        <input asp-for="UserNameOrEmail" class="form-control" autocomplete="username" placeholder="admin hoặc admin@cuaforum.vn" />
        <span asp-validation-for="UserNameOrEmail" class="field-validation-error"></span>
    </div>
    <div class="field">
        <label asp-for="Password"></label>
        <input asp-for="Password" class="form-control" autocomplete="current-password" />
        <span asp-validation-for="Password" class="field-validation-error"></span>
    </div>
    <label class="checkbox mb-10"><input asp-for="RememberMe" type="checkbox" /> @Html.DisplayNameFor(m => m.RememberMe)</label>
    <button type="submit" class="btn btn-primary btn-block">Đăng nhập</button>
</form>

<partial name="_SocialLogins" />
<p class="text-center small mt-8">Chưa có tài khoản? <a asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl">Đăng ký ngay</a></p>
<p class="text-center xsmall muted">Tài khoản demo: <code>demo</code> / <code>Test@@123</code></p>
