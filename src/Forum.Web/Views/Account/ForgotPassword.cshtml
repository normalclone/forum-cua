@model ForgotPasswordViewModel
<div class="card card-pad" style="max-width:460px; margin:24px auto;">
    <h1 style="font-size:1.3rem; margin-top:0;">@Html.Icon("key-round", 20) Quên mật khẩu</h1>
    @if (ViewBag.Sent == true)
    {
        <div class="card-pad small" style="background:var(--surface-2); border-radius:8px;">
            Nếu email tồn tại, chúng tôi đã gửi liên kết đặt lại mật khẩu. Vui lòng kiểm tra hộp thư.
            @if (ViewBag.DevLink != null)
            {
                <div class="mt-8 small">🔧 <b>Chế độ dev</b> (chưa cấu hình SMTP): <a href="@ViewBag.DevLink">bấm vào đây để đặt lại mật khẩu</a></div>
            }
        </div>
        <div class="mt-8"><a class="btn" href="/dang-nhap">Về đăng nhập</a></div>
    }
    else
    {
        <p class="muted small">Nhập email đăng ký, chúng tôi sẽ gửi liên kết đặt lại mật khẩu.</p>
        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors mb-10"></div>
            <div class="field">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>
            <div class="flex gap-6 mt-8">
                <button class="btn btn-primary" type="submit">Gửi liên kết đặt lại</button>
                <a class="btn" href="/dang-nhap">Quay lại</a>
            </div>
        </form>
    }
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
