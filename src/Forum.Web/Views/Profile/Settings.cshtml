@model EditProfileViewModel
<div style="max-width:560px; margin:0 auto;">
    <h1 style="font-size:1.4rem;">Cài đặt hồ sơ</h1>
    <div class="card card-pad">
        <form asp-action="Settings" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors mb-10"></div>
            <div class="field">
                <label asp-for="DisplayName"></label>
                <input asp-for="DisplayName" class="form-control" />
                <span asp-validation-for="DisplayName" class="field-validation-error"></span>
            </div>
            <div class="field">
                <label asp-for="Trade"></label>
                <select asp-for="Trade" class="form-control">
                    @foreach (var t in Enum.GetValues<UserTrade>())
                    {
                        <option value="@t">@ViewHelpers.TradeLabel(t)</option>
                    }
                </select>
            </div>
            <div class="field">
                <label asp-for="Location"></label>
                <input asp-for="Location" class="form-control" placeholder="VD: Hà Nội" />
            </div>
            <div class="field">
                <label asp-for="AvatarUrl"></label>
                <input asp-for="AvatarUrl" class="form-control" placeholder="https://… (để trống dùng avatar chữ cái)" />
                <span asp-validation-for="AvatarUrl" class="field-validation-error"></span>
            </div>
            <div class="field">
                <label asp-for="Bio"></label>
                <textarea asp-for="Bio" class="form-control" rows="4" placeholder="Giới thiệu ngắn về bạn…"></textarea>
                <span asp-validation-for="Bio" class="field-validation-error"></span>
            </div>
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        </form>
    </div>
</div>
