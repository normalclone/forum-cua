@model List<Topic>
<h1 style="font-size:1.4rem;">@Html.Icon("bookmark", 22) Chủ đề đã lưu</h1>
@if (Model.Count == 0)
{
    <div class="empty">
        <div class="ico">@Html.Icon("bookmark", 40)</div>
        <h3>Chưa lưu chủ đề nào</h3>
        <p class="muted">Bấm "Lưu" trên một chủ đề để xem lại sau.</p>
        <a class="btn btn-primary" href="/">Khám phá chủ đề</a>
    </div>
}
else
{
    <div class="topic-list">
        @foreach (var t in Model)
        {
            <partial name="_TopicCard" model="t" />
        }
    </div>
}
