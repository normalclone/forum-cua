@model PagerModel
@if (Model.TotalPages > 1)
{
    var start = Math.Max(1, Model.Page - 2);
    var end = Math.Min(Model.TotalPages, Model.Page + 2);
    <nav class="pager" aria-label="Phân trang">
        @if (Model.Page > 1)
        {
            <a href="@Model.Url(Model.Page - 1)" rel="prev">@Html.Icon("chevron-up", 14) Trước</a>
        }
        else
        {
            <span class="disabled">Trước</span>
        }

        @if (start > 1)
        {
            <a href="@Model.Url(1)">1</a>
            @if (start > 2)
            {
                <span class="disabled">…</span>
            }
        }

        @for (var p = start; p <= end; p++)
        {
            if (p == Model.Page)
            {
                <span class="current" aria-current="page">@p</span>
            }
            else
            {
                <a href="@Model.Url(p)">@p</a>
            }
        }

        @if (end < Model.TotalPages)
        {
            @if (end < Model.TotalPages - 1)
            {
                <span class="disabled">…</span>
            }
            <a href="@Model.Url(Model.TotalPages)">@Model.TotalPages</a>
        }

        @if (Model.Page < Model.TotalPages)
        {
            <a href="@Model.Url(Model.Page + 1)" rel="next">Sau @Html.Icon("chevron-down", 14)</a>
        }
        else
        {
            <span class="disabled">Sau</span>
        }
    </nav>
}
