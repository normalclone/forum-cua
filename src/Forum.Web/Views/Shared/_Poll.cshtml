@model TopicDetailViewModel
@{
    var poll = Model.Topic.Poll!;
    var total = Model.PollTotalVotes;
    var votedId = Model.UserPollOptionId;
    var showResults = votedId.HasValue;
}
<div class="poll" data-poll="@poll.Id" data-voted="@showResults.ToString().ToLower()">
    <div class="flex items-center gap-6 mb-10"><b>@Html.Icon("bar-chart", 16) @poll.Question</b></div>
    <div class="poll-options">
        @foreach (var o in poll.Options.OrderBy(x => x.DisplayOrder))
        {
            var pct = total > 0 ? (int)Math.Round(o.VoteCount * 100.0 / total) : 0;
            <button class="poll-opt @(votedId == o.Id ? "voted" : "")" data-option="@o.Id" type="button">
                <span class="bar" style="width:@(showResults ? pct : 0)%"></span>
                <span class="lbl">@o.Text</span>
                <span class="pct" style="@(showResults ? "" : "display:none")">@pct% · @o.VoteCount</span>
            </button>
        }
    </div>
    <div class="xsmall muted mt-8"><span class="poll-total">@total</span> lượt bình chọn@(showResults ? "" : " · bấm để bình chọn")</div>
</div>
